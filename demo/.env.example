# ── Required ──────────────────────────────────────────────────────────────────
# Your Anthropic API key (https://console.anthropic.com)
ANTHROPIC_API_KEY=

# Your Brave Search API key (https://api.search.brave.com)
BRAVE_API_KEY=

# ── Mode ──────────────────────────────────────────────────────────────────────
# true  → web content passes through CRE context firewall before Claude sees it
# false → web content goes directly to Claude (UNPROTECTED — for side-by-side demo)
WITH_CRE=true

# ── CRE connection (leave as-is for Docker Compose) ───────────────────────────
CRE_API_URL=http://cre:8080
CRE_API_TOKEN=demo-token

# ── Optional ──────────────────────────────────────────────────────────────────
# Number of Brave search results to fetch per query (1-10)
SEARCH_RESULTS=5
